# === Core ===
MUNIN_MEMORY_DB_PATH=~/.munin-memory/memory.db
MUNIN_MEMORY_MAX_CONTENT_SIZE=100000

# === Transport ===
MUNIN_TRANSPORT=stdio
MUNIN_HTTP_PORT=3030
MUNIN_HTTP_HOST=127.0.0.1

# === Auth (required for HTTP mode) ===
# Generate with: openssl rand -hex 32
MUNIN_API_KEY=

# === Owner compatibility ===
# Optional comma-separated natural-language names used by injection/orientation checks.
MUNIN_OWNER_ALIASES=
# Optional canonical profile namespace. Existing people/magnus data remains readable.
MUNIN_OWNER_PROFILE_NAMESPACE=people/owner

# === Operational backup (copy these to ~/munin-ops/.env) ===
# munin-backup.service has TWO destination modes. Configure exactly one. With
# neither configured the job refuses to start rather than writing nowhere.
#
# MUNIN_BACKUP_MODE may be left unset — it is inferred from whichever pair is
# present — but setting it explicitly makes the intent obvious in the .env.
#
# Mode 'remote': push the snapshot to another host over ssh/rsync. The transfer
# is verified by comparing the destination's byte count against the snapshot,
# because rsync exiting 0 does not prove the bytes are readable there.
# MUNIN_BACKUP_MODE=remote
# MUNIN_BACKUP_HOST=backup-user@backup-host
# MUNIN_BACKUP_REMOTE_DIR=/srv/backups/munin-memory
#
# Mode 'local': write the snapshot to a locally mounted volume. MUNIN_BACKUP_MOUNT
# must be the mounted filesystem root and MUNIN_BACKUP_DIR an absolute child of
# it. The mount is verified before AND after each write, symlinked path
# components are rejected, and the written file's filesystem identity is checked,
# so a dropped mount cannot silently redirect backups to the system disk.
MUNIN_BACKUP_MODE=local
MUNIN_BACKUP_MOUNT=/mnt/backup
MUNIN_BACKUP_DIR=/mnt/backup/munin-memory
# MUNIN_BACKUP_DB=/var/lib/grimnir/munin-memory/memory.db
# Staging holds a full snapshot before transfer; defaults to /tmp (a tmpfs under
# the unit's PrivateTmp=yes). Free space is preflighted. See munin-backup.service
# before pointing this at an SD card.
# MUNIN_BACKUP_STAGING=/tmp
# GFS retention, applied at either destination.
# MUNIN_BACKUP_KEEP_DAILY=14
# MUNIN_BACKUP_KEEP_SUNDAYS=4

# === Embeddings / Semantic Search ===
MUNIN_EMBEDDINGS_ENABLED=true
MUNIN_SEMANTIC_ENABLED=true
MUNIN_HYBRID_ENABLED=true
# Leave model, dtype, and batch unset to allow MUNIN_PROFILE defaults.
# MUNIN_EMBEDDINGS_MODEL=Xenova/bge-small-en-v1.5
# Leave unset to use the active profile/library precision default.
# MUNIN_EMBEDDINGS_DTYPE=q8
# MUNIN_EMBEDDINGS_BATCH_SIZE=25
MUNIN_EMBEDDINGS_BATCH_DELAY_MS=200
MUNIN_EMBEDDINGS_MAX_FAILURES=5
MUNIN_EMBEDDINGS_LOCAL_ONLY=false

# Optional hardware preset. Explicit variables above override profile defaults.
# Values: zero-appliance, zero-plus, full-node
MUNIN_PROFILE=

# === Optional LLM consolidation ===
MUNIN_CONSOLIDATION_ENABLED=false
MUNIN_LLM_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
MUNIN_LLM_HTTP_REFERER=https://github.com/Magnus-Gille/munin-memory

# === HTTP Hardening ===
# Comma-separated extra Host headers to accept (for reverse proxy)
MUNIN_ALLOWED_HOSTS=

# Optional Heimdall descriptor metadata (GET /heimdall.json)
MUNIN_HEIMDALL_NAMESPACE=standalone
MUNIN_INSTANCE_ID=munin-local
MUNIN_DEPLOY_HOST=localhost

# === OAuth (HTTP mode, for web/mobile clients) ===
# Set to your public domain in production
MUNIN_OAUTH_ISSUER_URL=http://localhost:3030
MUNIN_OAUTH_ACCESS_TOKEN_TTL=3600
MUNIN_OAUTH_REFRESH_TOKEN_TTL=2592000
# Optional dedicated wrapping key for encrypting confidential OAuth client secrets at rest.
# If unset, MUNIN_API_KEY is used instead.
MUNIN_OAUTH_CLIENT_SECRET_KEY=
# Public OAuth consent must be protected by a trusted proxy-authenticated header.
# Example: MUNIN_OAUTH_TRUSTED_USER_HEADER=cf-access-authenticated-user-email
#          MUNIN_OAUTH_TRUSTED_USER_VALUE=you@example.com
MUNIN_OAUTH_TRUSTED_USER_HEADER=
MUNIN_OAUTH_TRUSTED_USER_VALUE=
# Localhost consent stays enabled for local development by default.
MUNIN_OAUTH_ALLOW_LOCALHOST_CONSENT=true
